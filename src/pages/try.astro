---
// Try Page - Upload your messy desk and get AI tidy plan
---
import 'tailwindcss';

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Try TidySnap - Snap Once. Tidy Forever.</title>
  <meta name="description" content="Upload your messy desk photo and get AI-generated tidy plan with arrows">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-bg: #FAFAF9;
      --color-surface: #FFFFFF;
      --color-text: #1C1917;
      --color-accent: #059669;
    }
    body {
      font-family: 'Outfit', sans-serif;
      background-color: var(--color-bg);
    }
    .heading { font-family: 'Sora', sans-serif; }
    .hero-bg {
      background: linear-gradient(135deg, #059669 0%, #047857 50%, #10B981 100%);
    }
    .upload-zone {
      background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
      border: 2px dashed #e2e8f0;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .upload-zone:hover {
      border-color: #10B981;
      transform: translateY(-4px);
      box-shadow: 0 20px 40px -15px rgba(5, 150, 105, 0.25);
    }
    .result-image-container {
      position: relative;
      overflow: hidden;
    }
    .result-image-container img {
      transition: transform 0.3s ease;
      cursor: zoom-in;
    }
    .result-image-container.zoomed img {
      transform: scale(2);
      cursor: zoom-out;
    }
    .arrow-overlay {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
    .upload-zone.dragover {
      border-color: #10B981;
      background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
    }
    .result-card {
      background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
      border: 1px solid #e2e8f0;
      box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.1);
    }
    .btn-primary {
      background: linear-gradient(135deg, #059669 0%, #047857 100%);
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 15px 30px -10px rgba(5, 150, 105, 0.4);
    }
    .loading-spinner {
      border: 3px solid #e2e8f0;
      border-top: 3px solid #059669;
      border-radius: 50%;
      width: 50px;
      height: 50px;
      animation: spin 1s linear infinite;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    .fade-in {
      animation: fadeIn 0.5s ease-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .pulse-dot {
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-stone-50 via-white to-emerald-50">
  <!-- Navigation -->
  <nav class="bg-white/90 backdrop-blur-md border-b border-stone-100 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-10 h-10 bg-gradient-to-br from-emerald-600 to-emerald-700 rounded-xl flex items-center justify-center text-white text-xl shadow-lg shadow-emerald-600/20">
          📸
        </div>
        <span class="text-xl font-bold heading text-stone-800 group-hover:text-emerald-600 transition-colors">TidySnap</span>
      </a>
      <a href="/" class="text-stone-600 hover:text-emerald-600 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to Home
      </a>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero-bg text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-48 h-48 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-64 h-64 bg-emerald-300 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-4xl mx-auto px-4 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md px-4 py-2 rounded-full text-sm font-medium mb-6 border border-white/20">
        <span class="w-2 h-2 bg-emerald-300 rounded-full pulse-dot"></span>
        <span>AI-Powered Desk Organization</span>
      </div>
      <h1 class="heading text-4xl md:text-5xl font-bold mb-4">
        Snap Once. <span class="text-emerald-200">Tidy Forever.</span>
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Upload your messy desk photo and get an AI-generated tidy plan with arrows showing exactly where each item should go
      </p>
      
      <!-- User Status Badge -->
      <div id="user-status" class="mt-6 inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-md rounded-full text-sm border border-white/20 hidden">
        <span id="user-status-icon"></span>
        <span id="user-status-text"></span>
      </div>
    </div>
  </section>

  <!-- Auth Modal -->
  <div id="auth-modal" class="fixed inset-0 bg-black/50 backdrop-blur-md z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl p-8 max-w-md w-full shadow-2xl">
      <h2 class="heading text-2xl font-bold mb-4 text-stone-800">Sign In to Continue</h2>
      <p class="text-stone-600 mb-6">Enter your email or use Google to start organizing your desk with AI</p>
      
      <!-- Google Login Button -->
      <button id="google-login-btn" type="button" class="w-full flex items-center justify-center gap-3 px-6 py-3 bg-white border-2 border-stone-200 text-stone-700 rounded-xl font-semibold hover:bg-stone-50 transition-colors mb-4">
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continue with Google
      </button>
      
      <div class="relative my-4">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-stone-200"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-stone-500">or</span>
        </div>
      </div>
      
      <form id="auth-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Email</label>
          <input type="email" id="auth-email" required class="w-full px-4 py-3 border border-stone-200 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" placeholder="you@example.com">
        </div>
        <div class="flex gap-3">
          <button type="submit" name="action" value="register" class="flex-1 px-6 py-3 bg-emerald-600 text-white rounded-xl font-semibold hover:bg-emerald-700 transition-colors">
            Register
          </button>
          <button type="submit" name="action" value="login" class="flex-1 px-6 py-3 bg-stone-100 text-stone-700 rounded-xl font-semibold hover:bg-stone-200 transition-colors">
            Login
          </button>
        </div>
      </form>
      
      <button onclick="closeAuthModal()" class="mt-4 w-full text-center text-stone-500 hover:text-stone-700">
        Cancel
      </button>
    </div>
  </div>

  <!-- Upgrade Prompt -->
  <div id="upgrade-prompt" class="fixed inset-0 bg-black/50 backdrop-blur-md z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl p-8 max-w-md w-full shadow-2xl text-center">
      <div class="w-16 h-16 mx-auto bg-gradient-to-br from-emerald-100 to-emerald-200 rounded-full flex items-center justify-center mb-4">
        <span class="text-3xl">⚡</span>
      </div>
      <h2 class="heading text-2xl font-bold mb-2 text-stone-800">Free Limit Reached</h2>
      <p class="text-stone-600 mb-6">You've used your free analysis. Upgrade to lifetime access for unlimited AI desk organization plans!</p>
      
      <div class="mb-6">
        <div class="flex items-baseline justify-center gap-2 mb-2">
          <span class="text-3xl font-bold text-emerald-600">$49.99</span>
          <span class="text-lg text-stone-400 line-through">$99.99</span>
        </div>
        <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-sm font-medium">50% OFF Lifetime</span>
      </div>
      
      <button id="upgrade-btn" class="w-full px-6 py-3 bg-gradient-to-r from-emerald-600 to-teal-600 text-white rounded-xl font-semibold hover:opacity-90 transition-opacity mb-3">
        Upgrade Now
      </button>
      <button onclick="closeUpgradePrompt()" class="w-full text-center text-stone-500 hover:text-stone-700">
        Maybe Later
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <main class="max-w-6xl mx-auto px-4 py-12 -mt-8">
    <!-- Upload Zone -->
    <div id="upload-zone" class="upload-zone rounded-3xl p-12 text-center cursor-pointer mb-12">
      <div class="mb-6">
        <div class="w-24 h-24 mx-auto bg-gradient-to-br from-emerald-100 to-emerald-200 rounded-2xl flex items-center justify-center">
          <svg class="w-12 h-12 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
      <h3 class="heading text-2xl font-bold text-stone-800 mb-2">Drop your messy desk photo</h3>
      <p class="text-stone-500 mb-6">or click to browse files</p>
      <div class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 text-white rounded-xl font-medium">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Choose File
      </div>
      <input type="file" id="file-input" accept="image/*" class="hidden">
      <p class="text-xs text-stone-400 mt-6">Supports JPG, PNG, WEBP • Max 10MB</p>
    </div>

    <!-- Loading State -->
    <div id="loading" class="hidden text-center py-16">
      <div class="loading-spinner mx-auto mb-6"></div>
      <h3 class="heading text-2xl font-bold text-stone-800 mb-2">AI is analyzing your desk...</h3>
      <p class="text-stone-500">Identifying items and generating your personalized tidy plan</p>
      <div class="mt-8 flex justify-center gap-2">
        <div class="w-3 h-3 bg-emerald-600 rounded-full animate-bounce" style="animation-delay: 0ms;"></div>
        <div class="w-3 h-3 bg-emerald-600 rounded-full animate-bounce" style="animation-delay: 150ms;"></div>
        <div class="w-3 h-3 bg-emerald-600 rounded-full animate-bounce" style="animation-delay: 300ms;"></div>
      </div>
    </div>

    <!-- Error State -->
    <div id="error" class="hidden max-w-md mx-auto text-center py-12 px-6 bg-red-50 border border-red-200 rounded-3xl">
      <div class="w-16 h-16 mx-auto bg-red-100 rounded-full flex items-center justify-center mb-4">
        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h3 class="heading text-xl font-bold text-red-800 mb-2">Oops! Something went wrong</h3>
      <p class="text-red-600 mb-6" id="error-message"></p>
      <button onclick="resetUpload()" class="px-6 py-3 bg-red-600 text-white rounded-xl font-medium hover:bg-red-700 transition-colors">
        Try Again
      </button>
    </div>

    <!-- Result -->
    <div id="result" class="hidden fade-in">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Original Image -->
        <div class="result-card rounded-3xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
              <span class="text-xl">📸</span>
            </div>
            <h3 class="heading text-lg font-bold text-stone-800">Your Messy Desk</h3>
          </div>
          <div class="aspect-video bg-stone-100 rounded-2xl overflow-hidden">
            <img id="original-image" class="w-full h-full object-cover" alt="Original">
          </div>
        </div>
        
        <!-- Tidy Plan -->
        <div class="result-card rounded-3xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center">
              <span class="text-xl">✨</span>
            </div>
            <h3 class="heading text-lg font-bold text-stone-800">Your Tidy Plan</h3>
            <button id="zoom-btn" class="ml-auto p-2 bg-stone-100 rounded-lg hover:bg-stone-200 transition-colors" title="Zoom (click image)">
              <svg class="w-5 h-5 text-stone-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
            </button>
          </div>
          <div id="plan-container" class="result-image-container aspect-video bg-stone-100 rounded-2xl overflow-hidden mb-6 border-2 border-emerald-200">
            <img id="plan-image" class="w-full h-full object-contain bg-white" alt="Tidy Plan">
          </div>
          <div class="flex gap-3">
            <a id="download-btn" href="#" download="tidysnap-plan.png" class="btn-primary flex-1 text-center py-4 rounded-xl font-semibold text-white flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Download Plan
            </a>
            <button id="share-btn" class="px-6 py-4 bg-white border-2 border-stone-200 text-stone-700 rounded-xl font-semibold hover:border-emerald-500 hover:text-emerald-600 transition-colors flex items-center justify-center gap-2" title="Share">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <button onclick="resetUpload()" class="px-8 py-3 bg-white border-2 border-stone-200 text-stone-700 rounded-xl font-semibold hover:border-emerald-500 hover:text-emerald-600 transition-colors">
          Try Another Photo
        </button>
        <a href="/" class="px-8 py-3 bg-emerald-600 text-white rounded-xl font-semibold hover:bg-emerald-700 transition-colors text-center">
          Join Waitlist for Early Access
        </a>
      </div>
    </div>
  </main>

  <!-- Features Banner -->
  <section class="bg-white border-t border-stone-100 py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div class="p-6">
          <div class="w-14 h-14 mx-auto bg-gradient-to-br from-purple-100 to-purple-200 rounded-2xl flex items-center justify-center mb-4">
            <span class="text-2xl">🎯</span>
          </div>
          <h4 class="heading font-bold text-stone-800 mb-2">Smart Detection</h4>
          <p class="text-stone-500 text-sm">AI identifies items and suggests optimal placement</p>
        </div>
        <div class="p-6">
          <div class="w-14 h-14 mx-auto bg-gradient-to-br from-blue-100 to-blue-200 rounded-2xl flex items-center justify-center mb-4">
            <span class="text-2xl">➡️</span>
          </div>
          <h4 class="heading font-bold text-stone-800 mb-2">Arrow Guides</h4>
          <p class="text-stone-500 text-sm">Clear arrows show exactly where each item goes</p>
        </div>
        <div class="p-6">
          <div class="w-14 h-14 mx-auto bg-gradient-to-br from-emerald-100 to-emerald-200 rounded-2xl flex items-center justify-center mb-4">
            <span class="text-2xl">📥</span>
          </div>
          <h4 class="heading font-bold text-stone-800 mb-2">Download & Keep</h4>
          <p class="text-stone-500 text-sm">Save your personalized tidy plan forever</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-stone-900 text-white py-12">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="text-2xl">📸</span>
        <span class="heading text-xl font-bold">TidySnap</span>
      </div>
      <p class="text-stone-400 mb-6">Snap Once. Tidy Forever.</p>
      <p class="text-stone-500 text-sm">© 2026 TidySnap AI. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // User state
    let currentUser = null;
    let isLoggedIn = false;
    let isLifetime = false;
    let analysisCount = 0;

    const FREE_LIMIT = 1;

    const uploadZone = document.getElementById('upload-zone');
    const fileInput = document.getElementById('file-input');
    const loading = document.getElementById('loading');
    const result = document.getElementById('result');
    const error = document.getElementById('error');
    const errorMessage = document.getElementById('error-message');
    const authModal = document.getElementById('auth-modal');
    const upgradePrompt = document.getElementById('upgrade-prompt');

    // Check user status on load
    async function checkUserStatus() {
      try {
        const res = await fetch('/api/subscription');
        const data = await res.json();
        
        if (data.loggedIn) {
          isLoggedIn = true;
          currentUser = data.user;
          isLifetime = data.user.subscription === 'lifetime';
          analysisCount = data.user.analysisCount || 0;
          updateUserStatus();
        }
      } catch (err) {
        console.error('Failed to check user status:', err);
      }
    }

    function updateUserStatus() {
      const statusEl = document.getElementById('user-status');
      const iconEl = document.getElementById('user-status-icon');
      const textEl = document.getElementById('user-status-text');
      
      if (!isLoggedIn) {
        statusEl.classList.add('hidden');
        return;
      }
      
      statusEl.classList.remove('hidden');
      
      if (isLifetime) {
        iconEl.textContent = '⭐';
        textEl.textContent = 'Lifetime Member • Unlimited';
      } else {
        const remaining = Math.max(0, FREE_LIMIT - analysisCount);
        iconEl.textContent = '👤';
        textEl.textContent = `Free Plan • ${remaining} free analysis left`;
      }
    }

    // Auth modal
    function showAuthModal() {
      authModal.classList.remove('hidden');
    }

    function closeAuthModal() {
      authModal.classList.add('hidden');
    }

    // Google Login
    function handleGoogleLogin(googleToken) {
      fetch('/api/auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          action: 'google_login', 
          googleToken: googleToken,
          email: window.googleUser?.email 
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          isLoggedIn = true;
          currentUser = data.user;
          isLifetime = data.user.subscription === 'lifetime';
          analysisCount = data.user.analysisCount || 0;
          closeAuthModal();
          updateUserStatus();
        } else {
          alert(data.error || 'Google login failed');
        }
      })
      .catch(err => alert('Error: ' + err.message));
    }

    // Initialize Google Identity Services
    if (window.google && window.google.accounts) {
      window.google.accounts.oauth2.initTokenClient({
        client_id: '1011912925260-sttjvvqoomjls348ndipcm5fiu2pq9kf.apps.googleusercontent.com',
        scope: 'email profile',
        callback: (response) => {
          if (response.access_token) {
            // Get user info
            fetch('https://www.googleapis.com/oauth2/v3/userinfo', {
              headers: { 'Authorization': `Bearer ${response.access_token}` }
            })
            .then(res => res.json())
            .then(userInfo => {
              window.googleUser = userInfo;
              handleGoogleLogin(response.access_token);
            });
          }
        }
      });
    }

    document.getElementById('google-login-btn')?.addEventListener('click', () => {
      if (window.google && window.google.accounts && window.google.accounts.oauth2) {
        const client = window.google.accounts.oauth2.initTokenClient({
          client_id: '1011912925260-sttjvvqoomjls348ndipcm5fiu2pq9kf.apps.googleusercontent.com',
          scope: 'email profile',
          callback: (response) => {
            if (response.access_token) {
              fetch('https://www.googleapis.com/oauth2/v3/userinfo', {
                headers: { 'Authorization': `Bearer ${response.access_token}` }
              })
              .then(res => res.json())
              .then(userInfo => {
                window.googleUser = userInfo;
                handleGoogleLogin(response.access_token);
              });
            }
          }
        });
        client.requestAccessToken();
      } else {
        alert('Google login not initialized. Please set your Google Client ID in .env.local');
      }
    });

    document.getElementById('auth-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('auth-email').value;
      const action = e.submitter.value;
      
      const formData = new FormData();
      formData.append('email', email);
      formData.append('action', action);
      
      try {
        const res = await fetch('/api/auth', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();
        
        if (data.success) {
          isLoggedIn = true;
          currentUser = data.user;
          isLifetime = data.user.subscription === 'lifetime';
          analysisCount = data.user.analysisCount || 0;
          closeAuthModal();
          updateUserStatus();
        } else {
          alert(data.error || 'Auth failed');
        }
      } catch (err) {
        alert('Error: ' + err.message);
      }
    });

    // Upgrade prompt
    function showUpgradePrompt() {
      upgradePrompt.classList.remove('hidden');
    }

    function closeUpgradePrompt() {
      upgradePrompt.classList.add('hidden');
    }

    document.getElementById('upgrade-btn')?.addEventListener('click', async () => {
      if (!currentUser?.email) {
        showAuthModal();
        closeUpgradePrompt();
        return;
      }
      
      const res = await fetch('/api/checkout', {
        method: 'POST',
        body: new FormData().append('email', currentUser.email)
      });
      
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        alert('Error: ' + (data.error || 'Checkout failed'));
      }
    });

    // Check if user can analyze
    function canAnalyze() {
      if (!isLoggedIn) {
        showAuthModal();
        return false;
      }
      if (!isLifetime && analysisCount >= FREE_LIMIT) {
        showUpgradePrompt();
        return false;
      }
      return true;
    }

    // Upload handling
    uploadZone.addEventListener('click', () => fileInput.click());
    uploadZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadZone.classList.add('dragover');
    });
    uploadZone.addEventListener('dragleave', () => {
      uploadZone.classList.remove('dragover');
    });
    uploadZone.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      const file = e.dataTransfer.files[0];
      if (file) handleFile(file);
    });
    fileInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) handleFile(file);
    });

    async function handleFile(file) {
      if (!canAnalyze()) return;
      
      if (!file.type.startsWith('image/')) {
        showError('Please upload an image file');
        return;
      }
      if (file.size > 10 * 1024 * 1024) {
        showError('File size must be less than 10MB');
        return;
      }

      // Show preview
      const reader = new FileReader();
      reader.onload = (e) => {
        document.getElementById('original-image').src = e.target.result;
      };
      reader.readAsDataURL(file);

      // Upload and analyze
      uploadZone.classList.add('hidden');
      loading.classList.remove('hidden');
      error.classList.add('hidden');
      result.classList.add('hidden');

      try {
        const formData = new FormData();
        formData.append('image', file);

        const response = await fetch('/api/analyze', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (!response.ok || data.error) {
          throw new Error(data.error || 'Analysis failed');
        }

        if (data.imageUrl) {
          document.getElementById('plan-image').src = data.imageUrl;
          document.getElementById('download-btn').href = data.imageUrl;
        } else if (data.plan) {
          document.getElementById('plan-container').innerHTML = `
            <div class="p-6 bg-emerald-50 rounded-2xl">
              <h4 class="font-bold text-emerald-800 mb-3 flex items-center gap-2">
                <span>✨</span> Your Tidy Plan:
              </h4>
              <div class="text-emerald-700 whitespace-pre-line">${data.plan}</div>
            </div>
          `;
        }

        // Update count (would normally call API)
        analysisCount++;
        updateUserStatus();

        loading.classList.add('hidden');
        result.classList.remove('hidden');

      } catch (err) {
        showError(err.message);
      }
    }

    function showError(msg) {
      loading.classList.add('hidden');
      result.classList.add('hidden');
      uploadZone.classList.remove('hidden');
      errorMessage.textContent = msg;
      error.classList.remove('hidden');
    }

    function resetUpload() {
      uploadZone.classList.remove('hidden');
      loading.classList.add('hidden');
      result.classList.add('hidden');
      error.classList.add('hidden');
      fileInput.value = '';
      // Reset zoom state
      const planContainer = document.getElementById('plan-container');
      if (planContainer) planContainer.classList.remove('zoomed');
    }

    // Expose functions to window for inline onclick handlers
    window.closeAuthModal = closeAuthModal;
    window.closeUpgradePrompt = closeUpgradePrompt;
    window.resetUpload = resetUpload;

    // Zoom functionality
    const planContainer = document.getElementById('plan-container');
    const zoomBtn = document.getElementById('zoom-btn');
    let isZoomed = false;

    if (planContainer) {
      planContainer.addEventListener('click', () => {
        isZoomed = !isZoomed;
        planContainer.classList.toggle('zoomed', isZoomed);
      });
    }

    if (zoomBtn) {
      zoomBtn.addEventListener('click', () => {
        isZoomed = !isZoomed;
        planContainer?.classList.toggle('zoomed', isZoomed);
      });
    }

    // Share functionality
    document.getElementById('share-btn')?.addEventListener('click', async () => {
      const planImage = document.getElementById('plan-image');
      if (!planImage?.src || planImage.src.includes('data:')) {
        alert('No image to share yet');
        return;
      }
      
      try {
        // Try Web Share API if available
        if (navigator.share) {
          const blob = await fetch(planImage.src).then(r => r.blob());
          const file = new File([blob], 'tidysnap-plan.png', { type: 'image/png' });
          await navigator.share({
            title: 'My TidySnap Plan',
            text: 'Check out my desk organization plan from TidySnap!',
            files: [file]
          });
        } else {
          // Fallback: copy image to clipboard
          const canvas = document.createElement('canvas');
          const ctx = canvas.getContext('2d');
          const img = new Image();
          img.crossOrigin = 'anonymous';
          img.onload = async () => {
            canvas.width = img.width;
            canvas.height = img.height;
            ctx?.drawImage(img, 0, 0);
            canvas.toBlob(async (blob) => {
              if (blob) {
                await navigator.clipboard.write([
                  new ClipboardItem({ 'image/png': blob })
                ]);
                alert('Image copied to clipboard!');
              }
            });
          };
          img.src = planImage.src;
        }
      } catch (err) {
        console.error('Share failed:', err);
        alert('Could not share image');
      }
    });

    // Initialize
    checkUserStatus();
  </script>
</body>
</html>
