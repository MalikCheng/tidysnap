  <!-- ═══════════════════════════════════════════
       JAVASCRIPT
       ═══════════════════════════════════════════ -->
  <script>
    // ── State ──────────────────────────────────
    let currentUser   = null;
    let isLoggedIn    = false;
    let isLifetime    = false;
    let analysisCount = 0;
    let isZoomed      = false;
    let modalStack    = [];   // only one modal open at a time

    const FREE_LIMIT = 1;

    let loadingPhaseTimer = null;
    let currentPhase = 0;

    function setLoadingStep(step) {
      const icons = ['📸', '🎨', '🏷️'];
      const titles = [
        'Scanning your desk…',
        'Creating your tidy vision…',
        'Adding item labels…',
      ];
      const subtitles = [
        'Analyzing your workspace layout',
        'Generating the perfect tidy plan',
        'Labeling each item for you',
      ];

      for (let i = 1; i <= 3; i++) {
        const el = document.getElementById(`step-${i}`);
        if (!el) continue;
        el.classList.remove('active', 'pending', 'done');
        if (i < step) el.classList.add('done');
        else if (i === step) el.classList.add('active');
        else el.classList.add('pending');
      }

      const iconEl = document.getElementById('loading-icon');
      const titleEl = document.getElementById('loading-title');
      const subtitleEl = document.getElementById('loading-subtitle');
      if (iconEl) iconEl.textContent = icons[step - 1] || '🧠';
      if (titleEl) titleEl.textContent = titles[step - 1] || 'Processing…';
      if (subtitleEl) subtitleEl.textContent = subtitles[step - 1] || '';
    }

    function startLoadingPhases() {
      currentPhase = 0;
      setLoadingStep(1);

      // Advance phases every 4 seconds
      if (loadingPhaseTimer) clearInterval(loadingPhaseTimer);
      loadingPhaseTimer = setInterval(() => {
        currentPhase++;
        if (currentPhase < 3) {
          setLoadingStep(currentPhase + 1);
        } else {
          clearInterval(loadingPhaseTimer);
        }
      }, 4000);
    }

    function stopLoadingPhases() {
      if (loadingPhaseTimer) {
        clearInterval(loadingPhaseTimer);
        loadingPhaseTimer = null;
      }
      currentPhase = 0;
    }

    // ── Elements ───────────────────────────────
    const uploadZone  = document.getElementById('upload-zone');
    const fileInput   = document.getElementById('file-input');
    const loadingEl   = document.getElementById('loading');
    const resultEl    = document.getElementById('result');
    const errorEl     = document.getElementById('error');
    const errorMsgEl  = document.getElementById('error-message');
    const authModal   = document.getElementById('auth-modal');
    const upgradeModal= document.getElementById('upgrade-modal');
    const planFrame   = document.getElementById('plan-frame');

    // ── User Status ─────────────────────────────
    async function checkUserStatus() {
      try {
        const res  = await fetch('/api/subscription');
        const data = await res.json();
        if (data.loggedIn) {
          isLoggedIn    = true;
          currentUser   = data.user;
          isLifetime     = data.user.subscription === 'lifetime';
          analysisCount = data.user.analysisCount || 0;
          renderUserBadge();
        }
      } catch (_) {}
    }

    function renderUserBadge() {
      const badge  = document.getElementById('user-badge');
      const icon   = document.getElementById('badge-icon');
      const text   = document.getElementById('badge-text');
      if (!isLoggedIn) { badge?.classList.add('hidden'); return; }
      badge?.classList.remove('hidden');
      if (isLifetime) {
        icon.textContent = '⭐';
        text.textContent = 'Lifetime Member · Unlimited';
      } else {
        const left = Math.max(0, FREE_LIMIT - analysisCount);
        icon.textContent = '👤';
        text.textContent = `Free Plan · ${left} free analysis left`;
      }
    }

    // ── Modal Stack (only one at a time) ────────
    function openModal(modal) {
      // Close any open modal first
      closeAllModals();
      modalStack.push(modal);
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal(modal) {
      modal.classList.remove('open');
      modalStack = modalStack.filter(m => m !== modal);
      document.body.style.overflow = '';
    }

    function closeAllModals() {
      [authModal, upgradeModal].forEach(closeModal);
    }

    window.closeAuthModal    = () => closeModal(authModal);
    window.closeUpgradeModal  = () => closeModal(upgradeModal);

    // Close on backdrop click
    [authModal, upgradeModal].forEach(modal => {
      modal.addEventListener('click', e => {
        if (e.target === modal) closeModal(modal);
      });
    });

    // ── Auth ───────────────────────────────────
    // Google OAuth
    document.getElementById('google-login-btn')?.addEventListener('click', () => {
      if (typeof google === 'undefined') {
        alert('Google OAuth is loading. Please try again in a moment.');
        return;
      }
      google.accounts.id.initialize({
        client_id: '1011912925260-sttjvvqoomjls348ndipcm5fiu2pq9kf.apps.googleusercontent.com',
        callback: async (response) => {
          if (response.error) {
            console.error('Google OAuth error:', response.error);
            return;
          }
          // Send token to our API
          await submitAuth('google_login', response.credential, null);
        }
      });
      google.accounts.id.prompt();
    });

    document.getElementById('auth-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email  = document.getElementById('auth-email').value;
      const action  = e.submitter.value;
      await submitAuth(action, null, email);
    });

    async function submitAuth(action, googleToken, email) {
      try {
        const body = googleToken
          ? JSON.stringify({ action, googleToken, email })
          : new URLSearchParams({ action, email });
        const res  = await fetch('/api/auth', {
          method: 'POST',
          headers: { 'Content-Type': googleToken ? 'application/json' : 'application/x-www-form-urlencoded' },
          body
        });
        const data = await res.json();
        if (data.success) {
          isLoggedIn    = true;
          currentUser   = data.user;
          isLifetime    = data.user.subscription === 'lifetime';
          analysisCount = data.user.analysisCount || 0;
          closeModal(authModal);
          renderUserBadge();
          // retry pending upload
          if (window._pendingFile) {
            const f = window._pendingFile;
            delete window._pendingFile;
            handleFile(f);
          }
        } else {
          alert(data.error || 'Authentication failed');
        }
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }

    // ── Upgrade ─────────────────────────────────
    document.getElementById('upgrade-btn')?.addEventListener('click', async () => {
      if (!currentUser?.email) {
        closeModal(upgradeModal);
        openModal(authModal);
        return;
      }
      const res  = await fetch('/api/checkout', {
        method: 'POST',
        body: new URLSearchParams({ email: currentUser.email })
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        alert('Error: ' + (data.error || 'Could not start checkout'));
      }
    });

    // ── Gate Check ──────────────────────────────
    function canAnalyze() {
      if (!isLoggedIn) {
        openModal(authModal);
        return false;
      }
      if (!isLifetime && analysisCount >= FREE_LIMIT) {
        openModal(upgradeModal);
        return false;
      }
      return true;
    }

    // ── Upload Zone ─────────────────────────────
    uploadZone.addEventListener('click',    () => fileInput.click());
    uploadZone.addEventListener('dragover',  e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
    uploadZone.addEventListener('dragleave',() => uploadZone.classList.remove('dragover'));
    uploadZone.addEventListener('drop', e => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      const file = e.dataTransfer.files[0];
      if (file) handleFile(file);
    });
    fileInput.addEventListener('change', () => {
      const file = fileInput.files[0];
      if (file) handleFile(file);
    });

    // ── Core Upload Flow ────────────────────────
    async function handleFile(file) {
      if (!canAnalyze()) {
        window._pendingFile = file; // save for after auth
        return;
      }

      if (!file.type.startsWith('image/')) {
        showError('Please upload an image file (JPG, PNG, or WEBP)');
        return;
      }
      if (file.size > 10 * 1024 * 1024) {
        showError('File size must be under 10 MB');
        return;
      }

      // Preview original
      const reader = new FileReader();
      reader.onload = e => {
        document.getElementById('original-image').src = e.target.result;
      };
      reader.readAsDataURL(file);

      // Transition states
      uploadZone.classList.add('hidden');
      loadingEl.classList.remove('hidden');
      errorEl.classList.add('hidden');
      resultEl.classList.add('hidden');

      // Start phase cycling
      startLoadingPhases();

      try {
        const formData = new FormData();
        formData.append('image', file);

        const res  = await fetch('/api/analyze', { method: 'POST', body: formData });
        const data = await res.json();

        // HTTP-level error
        if (!res.ok) throw new Error(data.error || 'Analysis failed');

        // Degraded mode (cleanImage failed) — show text plan with friendly notice
        if (data.degradedMode && (data.summary || data.plan)) {
          const frame = document.getElementById('plan-frame');
          frame.innerHTML = `
            <div class="degraded-card w-full h-full flex items-center justify-center p-5">
              <div class="text-left max-w-full">
                <div class="degraded-badge">⚡ Partial Result</div>
                <p class="text-amber-800 text-sm font-bold mb-3">Your Tidy Plan:</p>
                <div class="text-amber-700 text-sm whitespace-pre-line leading-relaxed">${data.summary || data.plan}</div>
                <p class="text-amber-600 text-xs mt-3">AI processing timed out — try again with a smaller image</p>
              </div>
            </div>`;
          stopLoadingPhases();
          loadingEl.classList.add('hidden');
          resultEl.classList.remove('hidden');
          return;
        }

        // Handle API response (Option B format)
        // Before: originalImage (base64 data URL)
        if (data.originalImage) {
          document.getElementById('original-image').src = data.originalImage;
        }

        // After: cleanImage (base64 data URL with arrows embedded)
        const afterImageUrl = data.cleanImage || data.imageUrl;
        if (afterImageUrl) {
          document.getElementById('plan-image').src = afterImageUrl;
          document.getElementById('plan-frame').classList.remove('hidden');

          // Render canvas arrows + HTML label overlays
          if (data.items && data.items.length > 0) {
            renderArrowsOnCanvas('arrow-canvas', 'plan-image', data.items);
            renderLabelsHTML('labels-container', 'plan-image', data.items);
          }

          // Download: if canvas arrows exist, use composited image; otherwise direct URL
          const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
          const arrowCanvas = document.getElementById('arrow-canvas') as HTMLCanvasElement;
          if (data.items && data.items.length > 0 && arrowCanvas && arrowCanvas.width > 0) {
            downloadBtn.href = '#';
            downloadBtn.onclick = async (e) => {
              e.preventDefault();
              downloadBtn.textContent = 'Generating…';
              try {
                const composite = await compositeArrowImage(afterImageUrl);
                downloadBtn.href = composite;
                downloadBtn.download = 'tidysnap-plan.png';
                downloadBtn.click();
              } catch {
                downloadBtn.href = afterImageUrl;
              } finally {
                downloadBtn.textContent = 'Download';
              }
            };
          } else {
            downloadBtn.href = afterImageUrl;
            downloadBtn.onclick = null;
          }
        } else if (data.summary || data.plan) {
          // Text-only plan fallback
          document.getElementById('plan-frame').innerHTML = `
            <div class="w-full h-full flex items-center justify-center bg-emerald-50 p-6">
              <div>
                <p class="font-bold text-emerald-800 mb-3 flex items-center gap-2 text-sm">
                  ✨ Your Tidy Plan:
                </p>
                <div class="text-emerald-700 text-sm whitespace-pre-line">${data.summary || data.plan}</div>
              </div>
            </div>`;
        } else {
          // Unexpected empty response
          throw new Error('No result returned. Please try again.');
        }

        analysisCount++;
        renderUserBadge();

        stopLoadingPhases();
        loadingEl.classList.add('hidden');
        resultEl.classList.remove('hidden');

      } catch (err) {
        showError(err.message);
      }
    }

    function showError(msg) {
      stopLoadingPhases();
      loadingEl.classList.add('hidden');
      resultEl.classList.add('hidden');
      uploadZone.classList.remove('hidden');
      errorMsgEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    window.resetUpload = function () {
      stopLoadingPhases();
      uploadZone.classList.remove('hidden');
      loadingEl.classList.add('hidden');
      resultEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      fileInput.value = '';
      isZoomed = false;
      planFrame?.classList.remove('zoomed');
    };

    // ── Zoom ───────────────────────────────────
    planFrame?.addEventListener('click', () => {
      isZoomed = !isZoomed;
      planFrame.classList.toggle('zoomed', isZoomed);
    });

    document.getElementById('zoom-btn')?.addEventListener('click', () => {
      isZoomed = !isZoomed;
      planFrame?.classList.toggle('zoomed', isZoomed);
    });

    // ── Canvas Arrow Renderer (v2 spec: blue #3B82F6, 3px, bezier curves) ──
    const ARROW_COLOR_V2 = '#3B82F6';

    function drawArrowV2(
      ctx: CanvasRenderingContext2D,
      fromX: number, fromY: number,
      toX: number, toY: number,
      label: string,
      scale: number
    ) {
      const stroke = 3;
      const headLen = Math.max(15, 20 * scale);
      const headWidth = Math.max(8, 12 * scale);

      const dx = toX - fromX;
      const dy = toY - fromY;
      const angle = Math.atan2(dy, dx);
      const length = Math.sqrt(dx * dx + dy * dy);

      // Control point for bezier curve (perpendicular offset for a gentle curve)
      const midX = (fromX + toX) / 2;
      const midY = (fromY + toY) / 2;
      const perpAngle = angle + Math.PI / 2;
      const curveOffset = Math.min(length * 0.15, 20 * scale);
      const ctrlX = midX + Math.cos(perpAngle) * curveOffset;
      const ctrlY = midY + Math.sin(perpAngle) * curveOffset;

      ctx.save();
      ctx.strokeStyle = ARROW_COLOR_V2;
      ctx.lineWidth = stroke;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      // Arrow body (bezier curve)
      ctx.beginPath();
      ctx.moveTo(fromX, fromY);
      ctx.quadraticCurveTo(ctrlX, ctrlY, toX, toY);
      ctx.stroke();

      // Arrow head
      const tipX = toX;
      const tipY = toY;
      const baseX = toX - Math.cos(angle) * headLen;
      const baseY = toY - Math.sin(angle) * headLen;

      ctx.beginPath();
      ctx.moveTo(tipX, tipY);
      ctx.lineTo(
        baseX + Math.cos(angle - 0.5) * headWidth,
        baseY + Math.sin(angle - 0.5) * headWidth
      );
      ctx.lineTo(
        baseX + Math.cos(angle + 0.5) * headWidth,
        baseY + Math.sin(angle + 0.5) * headWidth
      );
      ctx.closePath();
      ctx.fillStyle = ARROW_COLOR_V2;
      ctx.fill();

      // Label pill
      if (label) {
        const shortLabel = label.length > 12 ? label.substring(0, 11) + '…' : label;
        const fontSize = Math.max(11, 13 * scale);
        ctx.font = `600 ${fontSize}px 'Sora', 'Outfit', sans-serif`;
        const textMetrics = ctx.measureText(shortLabel);
        const labelPadX = 8 * scale;
        const labelPadY = 4 * scale;
        const labelW = textMetrics.width + labelPadX * 2;
        const labelH = fontSize + labelPadY * 2;
        // Position label at start of arrow, offset above
        const labelX = fromX - labelW / 2;
        const labelY = fromY - labelH - 10 * scale;

        // Label background (white with blue border)
        ctx.fillStyle = '#FFFFFF';
        ctx.strokeStyle = '#3B82F6';
        ctx.lineWidth = 2;
        ctx.beginPath();
        roundRect2(ctx, labelX, labelY, labelW, labelH, 8 * scale);
        ctx.fill();
        ctx.stroke();

        // Label text
        ctx.fillStyle = '#1F2937';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(shortLabel, fromX, labelY + labelH / 2);
      }

      ctx.restore();
    }

    function roundRect2(
      ctx: CanvasRenderingContext2D,
      x: number, y: number, w: number, h: number, r: number
    ) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w - r, y);
      ctx.quadraticCurveTo(x + w, y, x + w, y + r);
      ctx.lineTo(x + w, y + h - r);
      ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
      ctx.lineTo(x + r, y + h);
      ctx.quadraticCurveTo(x, y + h, x, y + h - r);
      ctx.lineTo(x, y + r);
      ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath();
    }

    function renderArrowsOnCanvas(canvasId: string, imgId: string, items: any[], maxArrows?: number) {
      const canvas = document.getElementById(canvasId) as HTMLCanvasElement;
      const img = document.getElementById(imgId) as HTMLImageElement;
      if (!canvas || !img || !items || items.length === 0) return;

      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const render = () => {
        const w = img.clientWidth || img.naturalWidth;
        const h = img.clientHeight || img.naturalHeight;
        canvas.width = w;
        canvas.height = h;

        const scaleX = w / 100;
        const scaleY = h / 100;

        ctx.clearRect(0, 0, w, h);

        const isMobile = window.innerWidth < 640;
        const limit = maxArrows || (isMobile ? 5 : 8);
        const count = Math.min(items.length, limit);

        for (let i = 0; i < count; i++) {
          const item = items[i];
          // Arrows: only draw if we have both from + to (directional arrows)
          if (item.from && item.to) {
            const fromX = item.from.x * scaleX;
            const fromY = item.from.y * scaleY;
            const toX = item.to.x * scaleX;
            const toY = item.to.y * scaleY;
            const emoji = item.emoji ? item.emoji + ' ' : '';
            const label = emoji + (item.name || item.targetPosition || '');
            drawArrowV2(ctx, fromX, fromY, toX, toY, label, 1);
          }
        }
      };

      if (img.complete && img.naturalWidth > 0) {
        render();
      } else {
        img.onload = render;
      }
    }

    function renderLabelsHTML(containerId: string, imgId: string, items: any[], maxLabels?: number) {
      const container = document.getElementById(containerId);
      const img = document.getElementById(imgId) as HTMLImageElement;
      if (!container || !img || !items || items.length === 0) return;

      const render = () => {
        container.innerHTML = '';

        const isMobile = window.innerWidth < 640;
        const limit = maxLabels || (isMobile ? 5 : 8);
        const count = Math.min(items.length, limit);

        for (let i = 0; i < count; i++) {
          const item = items[i];
          const pos = item.from || item.position;
          if (!pos) continue;

          const label = document.createElement('div');
          label.className = 'label-item';

          const emoji = item.emoji || '';
          const name = item.name || '';
          const subtitle = item.targetPosition ? '→ ' + item.targetPosition.split(' ').slice(0, 2).join(' ') : '';

          label.style.left = `${pos.x}%`;
          label.style.top = `${pos.y}%`;
          label.innerHTML = `${emoji} ${name}${subtitle ? `<span>${subtitle}</span>` : ''}`;

          // Vertical offset for overlapping labels
          if (i > 0) {
            label.style.marginTop = `${(i % 3) * 28}px`;
          }

          container.appendChild(label);
        }
      };

      if (img.complete && img.naturalWidth > 0) {
        render();
      } else {
        img.onload = render;
      }
    }
    async function compositeArrowImage(cleanImgSrc: string): Promise<string> {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          const ctx = canvas.getContext('2d');
          if (!ctx) { reject(new Error('No 2D context')); return; }
          ctx.drawImage(img, 0, 0);
          const arrowCanvas = document.getElementById('arrow-canvas') as HTMLCanvasElement;
          if (arrowCanvas && arrowCanvas.width > 0) {
            ctx.drawImage(arrowCanvas, 0, 0, canvas.width, canvas.height);
          }
          resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = reject;
        img.src = cleanImgSrc;
      });
    }

    // ── Share ──────────────────────────────────
    document.getElementById('share-btn')?.addEventListener('click', async () => {
      const planImg = document.getElementById('plan-image') as HTMLImageElement;
      const afterImageUrl = planImg?.src;
      if (!afterImageUrl || afterImageUrl.includes('data:') === false && afterImageUrl.startsWith('data:')) {
        alert('No image to share yet');
        return;
      }
      try {
        if (navigator.share) {
          let blob: Blob;
          // If we have canvas arrows, composite them into the image
          const arrowCanvas = document.getElementById('arrow-canvas') as HTMLCanvasElement;
          if (arrowCanvas && arrowCanvas.width > 0 && afterImageUrl.startsWith('http')) {
            const composite = await compositeArrowImage(afterImageUrl);
            const res = await fetch(composite);
            blob = await res.blob();
          } else {
            const res = await fetch(afterImageUrl);
            blob = await res.blob();
          }
          const file = new File([blob], 'tidysnap-plan.png', { type: 'image/png' });
          await navigator.share({
            title: 'My TidySnap Plan',
            text: 'Check out my AI desk organization plan!',
            files: [file]
          });
        } else {
          // Fallback: copy image to clipboard
          const img = new Image();
          img.crossOrigin = 'anonymous';
          img.onload = async () => {
            const canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;
            ctx.drawImage(img, 0, 0);
            const arrowCanvas = document.getElementById('arrow-canvas') as HTMLCanvasElement;
            if (arrowCanvas && arrowCanvas.width > 0) {
              ctx.drawImage(arrowCanvas, 0, 0, canvas.width, canvas.height);
            }
            canvas.toBlob(async (b) => {
              if (b) {
                await navigator.clipboard.write([
                  new ClipboardItem({ 'image/png': b })
                ]);
                alert('Image copied to clipboard!');
              }
            });
          };
          img.src = afterImageUrl;
        }
      } catch (err) {
        console.error('Share failed:', err);
        alert('Could not share image');
      }
    });

    // ── Init ───────────────────────────────────
    // Handle post-Stripe checkout redirects
    const params = new URLSearchParams(window.location.search);
    const checkoutResult = params.get('checkout');

    if (checkoutResult === 'success') {
      // Clean URL immediately
      window.history.replaceState({}, '', window.location.pathname);
      // Re-check user status (webhook should have updated subscription)
      await checkUserStatus();
      renderUserBadge();
      // Show success toast
      const badge = document.getElementById('user-badge');
      if (badge) {
        badge.classList.remove('hidden');
        const icon = document.getElementById('badge-icon');
        const text = document.getElementById('badge-text');
        icon.textContent = '⭐';
        text.textContent = 'Lifetime Member · Unlimited';
      }
    } else if (checkoutResult === 'canceled') {
      window.history.replaceState({}, '', window.location.pathname);
    }

    checkUserStatus();
  </script>

</body>
</html>
