---
import BlogLayout from '../BlogLayout.astro';
import { getCollection } from 'astro:content';

function getReadingTime(content) {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  return Math.ceil(words / wordsPerMinute);
}

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts[0];
const regularPosts = posts.slice(1);

const sampleContent = `整理前后对比：真实用户 transformation 展示`;
const readingTime = getReadingTime(sampleContent);

function formatDate(date) {
  return date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
}

// Gradient palette matching homepage
const gradients = [
  { from: 'from-emerald-500', to: 'to-teal-600', ring: 'ring-emerald-500', light: 'bg-emerald-500' },
  { from: 'from-cyan-500', to: 'to-blue-600', ring: 'ring-cyan-500', light: 'bg-cyan-500' },
  { from: 'from-violet-500', to: 'to-purple-600', ring: 'ring-violet-500', light: 'bg-violet-500' },
  { from: 'from-amber-500', to: 'to-orange-600', ring: 'ring-amber-500', light: 'bg-amber-500' },
  { from: 'from-rose-500', to: 'to-pink-600', ring: 'ring-rose-500', light: 'bg-rose-500' },
  { from: 'from-teal-500', to: 'to-emerald-600', ring: 'ring-teal-500', light: 'bg-teal-500' },
];

function getGradient(index: number) {
  return gradients[index % gradients.length];
}
---

<BlogLayout title="Blog" description="TidySnap Blog - AI-powered desk organization tips">
  <!-- Fixed Glass Navbar -->
  <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex justify-between items-center">
      <a href="https://tidysnap.homes" class="flex items-center gap-2.5 group">
        <div class="w-9 h-9 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center text-white text-sm shadow-lg shadow-emerald-500/30 group-hover:shadow-emerald-500/50 transition-all duration-300 group-hover:scale-110 group-hover:rotate-3">
          📸
        </div>
        <span class="text-base font-bold heading text-white hidden sm:block">TidySnap</span>
      </a>

      <!-- Mobile Menu Button - increased touch target to 44px -->
      <button id="mobile-menu-btn" class="sm:hidden min-w-[44px] min-h-[44px] flex items-center justify-center text-stone-300 hover:text-white transition-colors rounded-lg hover:bg-stone-800/50" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <div class="hidden sm:flex items-center gap-3 sm:gap-5">
        <a href="/blog" class="text-sm font-medium text-emerald-400 relative group">
          Blog
          <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-emerald-400"></span>
        </a>
        <a href="https://tidysnap.homes/#waitlist" class="btn-primary px-4 py-2 text-sm font-medium rounded-xl text-white flex items-center gap-1.5">
          <span>Join</span>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </nav>

    <!-- Mobile Menu Dropdown -->
    <div id="mobile-menu" class="hidden sm:hidden bg-stone-900/95 backdrop-blur-lg border-t border-stone-800">
      <div class="px-4 py-3 space-y-2">
        <a href="/blog" class="block text-sm font-medium text-emerald-400 py-3 px-2 rounded-lg hover:bg-stone-800/50">Blog</a>
        <a href="https://tidysnap.homes/#waitlist" class="block btn-primary px-4 py-3 text-sm font-medium rounded-xl text-white text-center">
          Join Waitlist
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="pt-24 pb-14 sm:pt-28 sm:pb-18 bg-gradient-to-br from-stone-950 via-stone-900 to-stone-950 relative overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0">
      <!-- Grid Pattern -->
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"0.03\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
      <!-- Radial Gradient -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-emerald-500/10 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-0 right-0 w-[600px] h-[400px] bg-teal-500/8 rounded-full blur-[100px]"></div>
    </div>
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2.5 bg-emerald-500/15 border border-emerald-500/20 text-emerald-300 px-5 py-2 rounded-full text-sm font-medium mb-8 animate-[fade-in_0.6s_ease-out_forwards]">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
        </span>
        AI-Powered Desk Organization
      </div>
      
      <!-- Title -->
      <h1 class="heading text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white mb-6 tracking-tight animate-[fade-in_0.6s_ease-out_0.2s_forwards] opacity-0">
        TidySnap <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 via-teal-400 to-cyan-400">Blog</span>
      </h1>
      
      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-stone-400 max-w-2xl mx-auto leading-relaxed animate-[fade-in_0.6s_ease-out_0.4s_forwards] opacity-0">
        Discover tips, tricks, and insights about creating the perfect organized workspace with AI
      </p>
      
      <!-- Stats -->
      <div class="flex items-center justify-center gap-8 mt-10 animate-[fade-in_0.6s_ease-out_0.6s_forwards] opacity-0">
        <div class="text-center">
          <div class="heading text-2xl sm:text-3xl font-bold text-white">{posts.length}</div>
          <div class="text-xs text-stone-500 uppercase tracking-wider mt-1">Articles</div>
        </div>
        <div class="w-px h-10 bg-stone-700"></div>
        <div class="text-center">
          <div class="heading text-2xl sm:text-3xl font-bold text-white">∞</div>
          <div class="text-xs text-stone-500 uppercase tracking-wider mt-1">Possibilities</div>
        </div>
      </div>
    </div>
    
    <!-- Bottom Wave -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-stone-700 to-transparent"></div>
  </section>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="py-10 relative">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <!-- Section Label -->
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-gradient-to-br from-amber-400 to-orange-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-amber-500/25">⭐</div>
          <div>
            <h2 class="heading text-base font-bold text-stone-200">Featured Article</h2>
            <p class="text-xs text-stone-500">Handpicked for you</p>
          </div>
        </div>
        
        <!-- Featured Card -->
        <a href={`/blog/${featuredPost.id.replace(/\.md$/, '')}`} class="block group">
          <article class="relative bg-stone-900/80 backdrop-blur-sm rounded-3xl shadow-2xl shadow-black/30 border border-stone-800 overflow-hidden hover:shadow-emerald-500/10 hover:border-emerald-500/30 transition-all duration-500 hover:-translate-y-2">
            <!-- Gradient Glow -->
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-teal-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="grid md:grid-cols-5 gap-0 relative">
              <!-- Image Side -->
              <div class={`md:col-span-2 h-56 md:h-72 relative overflow-hidden group-hover:scale-105 transition-transform duration-700`}>
                {featuredPost.data.heroImage ? (
                  <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} class="w-full h-full object-cover" />
                ) : (
                <div class={`h-full w-full bg-gradient-to-br ${getGradient(0).from} ${getGradient(0).to} flex items-center justify-center relative overflow-hidden`}>
                  <!-- Texture -->
                  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M20 20.5V29m0-18v8.5m-8.5 9.5h17" stroke="%23ffffff" stroke-width="2" stroke-linecap="round" opacity="0.15"/%3E%3C/svg%3E')] opacity-60"></div>
                  <!-- Floating Elements -->
                  <div class="absolute top-4 right-4 w-20 h-20 bg-white/10 rounded-full blur-xl"></div>
                  <div class="absolute bottom-4 left-4 w-16 h-16 bg-white/10 rounded-full blur-lg"></div>
                  <span class="text-7xl filter drop-shadow-2xl relative z-10 transform group-hover:scale-110 transition-transform duration-500">📸</span>
                </div>
                )}
              </div>
              
              <!-- Content Side -->
              <div class="md:col-span-3 p-7 sm:p-9 flex flex-col justify-center bg-stone-900/50 group-hover:bg-stone-900/30 transition-colors duration-500">
                <!-- Tags -->
                <div class="flex flex-wrap gap-2 mb-4">
                  {featuredPost.data.tags.slice(0, 3).map((tag) => (
                    <span class="text-xs font-semibold text-emerald-400 bg-emerald-500/10 px-3 py-1.5 rounded-full border border-emerald-500/20">{tag}</span>
                  ))}
                </div>
                
                <!-- Title -->
                <h3 class="heading text-2xl sm:text-3xl font-bold text-white mb-3 group-hover:text-emerald-300 transition-colors duration-300">
                  {featuredPost.data.title}
                </h3>
                
                <!-- Description -->
                <p class="text-sm text-stone-400 mb-5 line-clamp-2 group-hover:text-stone-300 transition-colors duration-300">{featuredPost.data.description}</p>
                
                <!-- Meta -->
                <div class="flex items-center gap-5 text-xs text-stone-500 group-hover:text-stone-400 transition-colors duration-300">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    {formatDate(featuredPost.data.pubDate)}
                  </span>
                  <span class="w-1 h-1 bg-stone-600 rounded-full"></span>
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {readingTime} min read
                  </span>
                </div>
                
                <!-- Read More -->
                <div class="mt-6 flex items-center gap-2 text-emerald-400 font-medium group-hover:text-emerald-300 transition-colors duration-300">
                  <span>Read Article</span>
                  <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </div>
              </div>
            </div>
          </article>
        </a>
      </div>
    </section>
  )}

  <!-- All Posts Grid -->
  <section class="py-10 bg-stone-950">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <!-- Section Header -->
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gradient-to-br from-stone-700 to-stone-800 rounded-xl flex items-center justify-center text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
            </svg>
          </div>
          <div>
            <h2 class="heading text-base font-bold text-stone-200">All Articles</h2>
            <p class="text-xs text-stone-500">Latest insights & tips</p>
          </div>
        </div>
        <span class="text-xs font-medium text-stone-500 bg-stone-800 px-3 py-1.5 rounded-full">{posts.length - 1} articles</span>
      </div>
      
      <!-- Posts Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {regularPosts.map((post, index) => {
          const gradient = getGradient(index + 1);
          return (
            <article class="post-card group bg-stone-900/60 backdrop-blur-sm rounded-2xl border border-stone-800 overflow-hidden hover:shadow-xl hover:shadow-emerald-500/10 hover:border-emerald-500/30 hover:-translate-y-2 transition-all duration-300">
              <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="block">
                <!-- Card Image -->
                {post.data.heroImage ? (
                <div class="h-40 relative overflow-hidden">
                  <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover" />
                </div>
                ) : (
                <div class={`h-40 bg-gradient-to-br ${gradient.from} ${gradient.to} flex items-center justify-center relative overflow-hidden`}>
                  <!-- Texture -->
                  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M20 20.5V29m0-18v8.5m-8.5 9.5h17" stroke="%23ffffff" stroke-width="2" stroke-linecap="round" opacity="0.1"/%3E%3C/svg%3E')] opacity-50"></div>
                  <!-- Glow -->
                  <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-white/20 rounded-full blur-2xl"></div>
                  <span class="text-5xl filter drop-shadow-lg relative z-10 transform group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">📸</span>
                </div>
                )}
                
                <!-- Card Content -->
                <div class="p-5">
                  <!-- Tags -->
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class="text-xs font-medium text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-full border border-emerald-500/20">{tag}</span>
                    ))}
                  </div>
                  
                  <!-- Title -->
                  <h3 class="heading text-base font-bold text-stone-200 mb-2 line-clamp-2 group-hover:text-emerald-300 transition-colors duration-300">
                    {post.data.title}
                  </h3>
                  
                  <!-- Description -->
                  <p class="text-xs text-stone-500 line-clamp-2 mb-4">{post.data.description}</p>
                  
                  <!-- Meta -->
                  <div class="flex items-center gap-3 text-xs text-stone-500">
                    <time class="flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                      {formatDate(post.data.pubDate)}
                    </time>
                    <span class="w-1 h-1 bg-stone-600 rounded-full"></span>
                    <span class="flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {readingTime} min
                    </span>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-600 via-emerald-700 to-teal-700"></div>
    <div class="absolute inset-0 opacity-30">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cpath d=\"M20 20.5V29m0-18v8.5m-8.5 9.5h17\" stroke=\"%23ffffff\" stroke-width=\"1.5\" stroke-linecap=\"round\"/%3E%3C/svg%3E')]"></div>
    </div>
    <!-- Glows -->
    <div class="absolute top-0 left-1/4 w-64 h-64 bg-white/10 rounded-full blur-[80px] group-hover:scale-110 transition-transform duration-700"></div>
    <div class="absolute bottom-0 right-1/4 w-48 h-48 bg-teal-400/20 rounded-full blur-[60px] group-hover:scale-125 transition-transform duration-700"></div>
    
    <div class="max-w-2xl mx-auto px-4 text-center relative">
      <h2 class="heading text-3xl sm:text-4xl font-bold text-white mb-4">Ready to transform your workspace?</h2>
      <p class="text-emerald-100 mb-8 text-lg">Join thousands of users who have already upgraded their desk setup with AI</p>
      <a href="https://tidysnap.homes/#waitlist" class="inline-flex items-center gap-3 bg-white text-emerald-700 px-8 py-4 font-bold rounded-2xl hover:bg-emerald-50 transition-all duration-300 shadow-xl hover:shadow-2xl hover:scale-105">
        Join Waitlist
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-stone-950 text-white py-12 relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-emerald-500/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-teal-500/5 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 relative">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center text-lg shadow-lg shadow-emerald-500/20">📸</div>
          <span class="text-lg font-bold heading">TidySnap</span>
        </div>
        <div class="flex gap-8 text-sm text-stone-400">
          <a href="https://tidysnap.homes" class="hover:text-emerald-400 transition-colors">Home</a>
          <a href="/blog" class="hover:text-emerald-400 transition-colors">Blog</a>
          <a href="#" class="hover:text-emerald-400 transition-colors">Twitter</a>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t border-stone-800 text-center">
        <p class="text-xs text-stone-500">© 2026 TidySnap AI. All rights reserved.</p>
      </div>
    </div>
  </footer>
</BlogLayout>

<style>
  .line-clamp-2 { 
    display: -webkit-box; 
    -webkit-line-clamp: 2; 
    -webkit-box-orient: vertical; 
    overflow: hidden; 
  }

  /* Navbar blur effect on scroll */
  #navbar {
    background: rgba(15, 15, 15, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(55, 65, 81, 0.5);
  }

  /* Animation */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }

  /* Staggered animations for cards */
  .post-card {
    opacity: 0;
    animation: fade-in 0.5s ease-out forwards;
  }
  
  .post-card:nth-child(1) { animation-delay: 0.1s; }
  .post-card:nth-child(2) { animation-delay: 0.2s; }
  .post-card:nth-child(3) { animation-delay: 0.3s; }
  .post-card:nth-child(4) { animation-delay: 0.4s; }
  .post-card:nth-child(5) { animation-delay: 0.5s; }
  .post-card:nth-child(6) { animation-delay: 0.6s; }
</style>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  let lastScroll = 0;
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    
    if (currentScroll > 50) {
      navbar.style.background = 'rgba(15, 15, 15, 0.95)';
      navbar.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.3)';
    } else {
      navbar.style.background = 'rgba(15, 15, 15, 0.8)';
      navbar.style.boxShadow = 'none';
    }
    
    lastScroll = currentScroll;
  }, { passive: true });
  
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
    
    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
