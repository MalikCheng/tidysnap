---
import BlogLayout from '../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BlogLayout title="Blog" description="TidySnap Blog - AI-powered desk organization tips, tricks, and inspiration">
  <!-- Minimal Header -->
  <header class="border-b border-stone-100 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
    <nav class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="https://tidysnap.homes" class="flex items-center gap-x-3 group">
        <div class="w-9 h-9 bg-gradient-to-br from-emerald-600 to-emerald-700 rounded-lg flex items-center justify-center text-white text-lg shadow-sm group-hover:shadow-md transition-shadow duration-300">📸</div>
        <span class="text-xl font-semibold heading text-stone-800">TidySnap</span>
      </a>
      <a href="https://tidysnap.homes/#waitlist" class="btn-primary px-5 py-2 text-sm font-medium rounded-lg text-white">
        Join Waitlist
      </a>
    </nav>
  </header>

  <!-- Editorial Hero -->
  <section class="bg-white pt-20 pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <span class="inline-block text-xs font-medium tracking-widest text-emerald-600 uppercase mb-5">Blog</span>
      <h1 class="heading text-5xl sm:text-6xl font-semibold text-stone-900 leading-[1.1] tracking-tight mb-6">
        Insights on <span class="text-emerald-700">desk organization</span>
      </h1>
      <p class="text-xl text-stone-500 leading-relaxed max-w-xl">
        Practical tips, creative ideas, and inspiration for creating a workspace that helps you focus and thrive.
      </p>
    </div>
  </section>

  <!-- Editorial Post List -->
  <section class="py-12 bg-stone-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="space-y-1">
        {posts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="py-7 px-6 -mx-6 rounded-xl hover:bg-white hover:shadow-sm hover:shadow-stone-100/50 transition-all duration-300">
                <div class="flex flex-col sm:flex-row sm:items-baseline gap-4 sm:gap-12">
                  <!-- Date -->
                  <time class="text-sm text-stone-400 font-medium w-32 shrink-0 tabular-nums">
                    {post.data.pubDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>

                  <!-- Content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-2">
                      <h2 class="heading text-xl sm:text-2xl font-semibold text-stone-800 group-hover:text-emerald-700 transition-colors duration-200 truncate">
                        {post.data.title}
                      </h2>
                      <span class="hidden sm:inline-block opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-stone-400">
                        →
                      </span>
                    </div>
                    <p class="text-stone-500 text-base leading-relaxed line-clamp-2 mb-3">
                      {post.data.description}
                    </p>
                    <div class="flex gap-2">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="text-xs font-medium text-stone-400 bg-stone-100 px-2 py-1 rounded-md">{tag}</span>
                      ))}
                    </div>
                  </div>

                  <!-- Decorative thumbnail -->
                  <div class="hidden lg:block w-28 h-20 rounded-lg overflow-hidden shrink-0 opacity-60 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="w-full h-full bg-gradient-to-br from-emerald-100 to-emerald-200 flex items-center justify-center text-2xl">
                      📸
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Elegant CTA -->
  <section class="py-24 bg-gradient-to-br from-stone-900 via-stone-800 to-stone-900 text-white relative overflow-hidden">
    <!-- Subtle pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>
    <div class="max-w-2xl mx-auto px-6 text-center relative">
      <h2 class="heading text-3xl sm:text-4xl font-semibold mb-4 tracking-tight">Transform your workspace today</h2>
      <p class="text-stone-300 mb-10 text-lg">Join thousands waiting for AI-powered desk organization</p>
      <a href="https://tidysnap.homes/#waitlist" class="btn-primary inline-flex items-center gap-2 px-8 py-4 text-base font-medium rounded-xl text-white transition-all hover:scale-[1.02] hover:shadow-lg hover:shadow-emerald-500/25">
        Join the Waitlist
        <span aria-hidden="true" class="text-lg">→</span>
      </a>
    </div>
  </section>

  <!-- Minimal Footer -->
  <footer class="bg-stone-950 text-white py-10">
    <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-stone-500 text-sm">© 2026 TidySnap AI</p>
      <div class="flex gap-6 text-stone-500 text-sm">
        <a href="https://tidysnap.homes" class="hover:text-white transition-colors">Home</a>
        <a href="https://tidysnap.homes/#waitlist" class="hover:text-white transition-colors">Join Waitlist</a>
      </div>
    </div>
  </footer>
</BlogLayout>

<style>
  .btn-primary {
    background: linear-gradient(135deg, #059669 0%, #047857 100%);
    transition: all 0.2s ease;
  }
  .btn-primary:hover {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tabular-nums {
    font-variant-numeric: tabular-nums;
  }
</style>
